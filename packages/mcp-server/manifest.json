{
  "dxt_version": "0.2",
  "name": "nimble-js-mcp",
  "version": "0.8.0",
  "description": "The official MCP Server for the Nimble API",
  "author": {
    "name": "Nimble",
    "email": "support@nimbleway.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nimbleway/nimble-typescript.git"
  },
  "homepage": "https://github.com/Nimbleway/nimble-typescript/tree/main/packages/mcp-server#readme",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/index.js"],
      "env": {
        "NIMBLE_API_KEY": "${user_config.NIMBLE_API_KEY}"
      }
    }
  },
  "user_config": {
    "NIMBLE_API_KEY": {
      "title": "api_key",
      "description": "",
      "required": false,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": ["api"]
}
